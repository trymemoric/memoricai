{
  "name": "memoricai",
  "version": "0.1.0",
  "description": "TypeScript SDK for the memoricai /v1 HTTP API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
